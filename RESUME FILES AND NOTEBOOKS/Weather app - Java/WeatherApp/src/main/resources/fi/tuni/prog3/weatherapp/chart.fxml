          <CategoryAxis label="Aika" side="BOTTOM" tickLabelGap="5.0" fx:id="xAxis" />
        </xAxis>
        <yAxis>
          <NumberAxis fx:id="yAxis" label="Lämpötila °C" lowerBound="-25.0" side="LEFT" upperBound="35.0">
