                  <Font size="10.0" />
               </tickLabelFont>
            </NumberAxis>
        </yAxis>
      </LineChart>
      <Button layoutX="24.0" layoutY="352.0" mnemonicParsing="false" onAction="#back" text="Sulje" />
   </children>
</AnchorPane>
